# Optional automatic S2 refresh credentials for local CLI/app runs.
# If these are blank, users can enter S2 ID/PW in the app sidebar.
S2_API_BASE_URL=https://kiss-api.kld.kr
S2_ID=
S2_PW=
# Optional: if set, S2 refresh skips the login request and uses this bearer token.
S2_ACCESS_TOKEN=
IPS_ID=
IPS_PW=

# Legacy aliases are still supported for existing local setups.
KISS_BASE_URL=https://kiss.kld.kr
KISS_API_BASE_URL=https://kiss-api.kld.kr
KIPM_BASE_URL=https://kiss.kld.kr
KISS_ID=
KISS_PW=
KIPM_ID=
KIPM_PW=
KLD_LOGIN_ID=
KLD_LOGIN_PW=
